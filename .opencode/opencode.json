{
  "$schema": "https://opencode.ai/config.json",
  "username": "sandikodev",
  "default_agent": "build",
  "instructions": [
    ".opencode/SHARED/project-context.md",
    ".opencode/SHARED/agent-rules.md"
  ],
  "references": {
    "docs": {
      "path": "../../smauii-aksesekolah/docs",
      "description": "Dokumentasi teknis SMART Absen — arsitektur, ERD, deployment"
    },
    "monorepo": {
      "path": "../../smauii-aksesekolah",
      "description": "Monorepo entrypoint — brief, docs, .opencode, .openkb"
    },
    "playbook": {
      "path": "../../smauii-playbook",
      "description": "SOP, workflow, template, ADR, role definitions, AI workflows"
    },
    "kaede": {
      "path": "../../kaede-powerup",
      "description": "KAEDE — Trello MCP, CLI tools & AI Agent ecosystem. Install: cd kaede-powerup && node scripts/kaede.mjs install"
    }
  },
  "agent": {
    "build": {
      "description": "Agent utama — coding Laravel, debugging, testing",
      "mode": "primary",
      "permission": {
        "edit": "allow",
        "bash": "ask"
      }
    },
    "plan": {
      "description": "Agent perencanaan — analisis sebelum coding",
      "mode": "primary",
      "permission": {
        "edit": "deny"
      }
    }
  },
  "command": {
    "test": {
      "description": "Jalankan PHPUnit test",
      "template": "php artisan test $ARGUMENTS"
    },
    "lint": {
      "description": "Cek coding style dengan Laravel Pint",
      "template": "./vendor/bin/pint --test"
    },
    "fix": {
      "description": "Perbaiki coding style otomatis",
      "template": "./vendor/bin/pint"
    },
    "migrate": {
      "description": "Jalankan migrasi database",
      "template": "php artisan migrate $ARGUMENTS"
    },
    "fresh": {
      "description": "Migrate fresh + seed",
      "template": "php artisan migrate:fresh --seed"
    },
    "kaede-today": {
      "description": "Tampilkan task Trello hari ini",
      "template": "kaede today"
    },
    "kaede-status": {
      "description": "Cek status koneksi KAEDE & Trello",
      "template": "kaede status --mcp"
    },
    "kaede-run": {
      "description": "Eksekusi intent ke Trello (butuh --playbook & board)",
      "template": "kaede run --playbook '../smauii-playbook' --board $ARGUMENTS"
    },
    "kaede-orchestrate": {
      "description": "Muat konteks playbook",
      "template": "kaede orchestrate --playbook '../smauii-playbook' $ARGUMENTS"
    }
  }
}
